<!-- ===== 営業カレンダー ===== -->
<section class="section calendar-section" id="calendar" style="background: #F0F4F8;">
  <div class="container">
    <div class="section-title">
      <span>Calendar</span>
      <h2>営業日・予約状況</h2>
    </div>

    <!-- 凡例 -->
    <div class="cal-legend">
      <div class="cal-legend-item"><span class="cal-dot open"></span>余裕あり</div>
      <div class="cal-legend-item"><span class="cal-dot limited"></span>残りわずか</div>
      <div class="cal-legend-item"><span class="cal-dot full"></span>満席</div>
      <div class="cal-legend-item cal-legend-events">
        <span class="cal-ev-dot beach"></span>海水浴場<span class="cal-ev-dot puente"></span>PUENTE
      </div>
    </div>

    <!-- デスクトップ：月ナビ＋グリッド -->
    <div class="cal-desktop" id="cal-desktop">
      <div class="cal-month-nav">
        <button class="cal-nav-btn" id="cal-prev" onclick="calPrevMonth()">‹</button>
        <div class="cal-month-label" id="cal-month-label">読み込み中...</div>
        <button class="cal-nav-btn" id="cal-next" onclick="calNextMonth()">›</button>
      </div>
      <div class="cal-grid" id="cal-grid">
        <div class="cal-day-head">日</div><div class="cal-day-head">月</div>
        <div class="cal-day-head">火</div><div class="cal-day-head">水</div>
        <div class="cal-day-head">木</div><div class="cal-day-head">金</div>
        <div class="cal-day-head">土</div>
      </div>
    </div>

    <div class="cal-reserve-link">
      <a href="reserve.html" class="btn btn-primary" style="margin: 0 auto;">予約する</a>
    </div>
  </div>
</section>

<style>
/* ===== カレンダー共通 ===== */
.calendar-section { padding-top: 3rem; padding-bottom: 3rem; }

.cal-legend {
  display: flex; flex-wrap: wrap; gap: 0.75rem 1.5rem;
  justify-content: center; margin-bottom: 1.5rem; font-size: 0.78rem; color: #555;
}
.cal-legend-item { display: flex; align-items: center; gap: 0.35rem; }
.cal-dot {
  display: inline-block; width: 10px; height: 10px; border-radius: 50%;
}
.cal-dot.open    { background: #38A169; }
.cal-dot.limited { background: #D69E2E; }
.cal-dot.full    { background: #E53E3E; }
.cal-legend-events { gap: 0.35rem; }
.cal-ev-dot {
  display: inline-block; width: 8px; height: 8px; border-radius: 2px;
  margin: 0 0.1rem;
}
.cal-ev-dot.beach  { background: #2E8CB8; }
.cal-ev-dot.puente { background: #36B5A0; }

/* ===== グリッド（全デバイス共通） ===== */
.cal-desktop { display: block; }
.cal-mobile  { display: none; }

.cal-month-nav {
  display: flex; align-items: center; justify-content: center;
  gap: 1.5rem; margin-bottom: 1rem;
}
.cal-nav-btn {
  background: white; border: 1.5px solid #E2E8F0; border-radius: 8px;
  width: 36px; height: 36px; font-size: 1.1rem; cursor: pointer;
  color: #1A5276; display: flex; align-items: center; justify-content: center;
  transition: background 0.15s;
}
.cal-nav-btn:hover { background: #EBF8FF; }
.cal-nav-btn:disabled { opacity: 0.3; cursor: default; }
.cal-month-label { font-size: 1.05rem; font-weight: 800; color: #1A5276; min-width: 120px; text-align: center; }

.cal-grid {
  display: grid; grid-template-columns: repeat(7, 1fr);
  gap: 4px; background: #E2E8F0; border-radius: 12px; overflow: hidden; padding: 4px;
}
.cal-day-head {
  background: #1A5276; color: white; text-align: center;
  font-size: 0.72rem; font-weight: 700; padding: 0.4rem 0;
  border-radius: 6px;
}
.cal-day-head:first-child { color: #FCA5A5; }
.cal-day-head:last-child  { color: #93C5FD; }

.cal-cell {
  background: white; border-radius: 8px; min-height: 80px;
  padding: 0.4rem 0.45rem; position: relative;
}
.cal-cell.empty     { background: transparent; }
.cal-cell.off-season { background: #F7FAFC; }
.cal-cell.is-today  { outline: 2px solid #2E8CB8; outline-offset: -2px; }

.cal-date-num {
  font-size: 0.82rem; font-weight: 700; color: #2D3748; margin-bottom: 0.3rem;
  display: flex; align-items: baseline; gap: 3px;
}
.cal-cell.off-season .cal-date-num { color: #CBD5E0; }
.cal-date-sun .cal-date-num { color: #E53E3E; }
.cal-date-sat .cal-date-num { color: #3182CE; }
.cal-wx { font-size: 0.8rem; line-height: 1; }

/* テキストラベル */
.cal-lbl-bbq { font-size: 0.66rem; font-weight: 800; color: #7B3000; letter-spacing: 0.04em; }
.cal-lbl-sw  { font-size: 0.66rem; font-weight: 800; color: #2E8CB8; letter-spacing: 0.04em; }

/* ステータスドット */
.cal-s-dot { display: inline-block; width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; }
.cal-s-open    { background: #38A169; }
.cal-s-limited { background: #D69E2E; }
.cal-s-full    { background: #E53E3E; }
.cal-s-none    { background: #CBD5E0; }

/* クリック可能セル */
.cal-cell.is-link { cursor: pointer; transition: background 0.15s, box-shadow 0.15s; }
.cal-cell.is-link:hover { background: #EBF8FF; box-shadow: inset 0 0 0 1.5px #2E8CB8; }
.cal-card.is-link { cursor: pointer; transition: border-color 0.15s, box-shadow 0.15s; }
.cal-card.is-link:hover { border-color: #2E8CB8; box-shadow: 0 3px 12px rgba(46,140,184,0.2); }

/* アイコン行 */
.cal-icons {
  display: flex; flex-direction: column; gap: 3px;
}
.cal-icon-row {
  display: flex; align-items: center; gap: 5px;
}

/* イベントドット */
.cal-events {
  display: flex; flex-wrap: wrap; gap: 2px; margin-top: 3px;
}
.cal-event-chip {
  font-size: 0.6rem; font-weight: 700; padding: 1px 4px; border-radius: 3px;
  max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  line-height: 1.4;
}
.cal-event-chip.beach  { background: #BEE3F8; color: #2C5282; }
.cal-event-chip.puente { background: #B2F5EA; color: #276749; }

/* ===== スマホ：月間グリッドをコンパクトに ===== */
@media (max-width: 767px) {
  .cal-cell {
    min-height: 62px;
    padding: 0.22rem 0.18rem;
  }
  .cal-date-num {
    font-size: 0.7rem;
    margin-bottom: 0.15rem;
    gap: 2px;
  }
  .cal-wx { font-size: 0.68rem; }
  .cal-icons { gap: 2px; }
  .cal-icon-row { gap: 3px; }
  .cal-lbl-bbq,
  .cal-lbl-sw  { font-size: 0.52rem; letter-spacing: 0; }
  .cal-s-dot   { width: 7px; height: 7px; }
  .cal-month-nav { gap: 0.75rem; margin-bottom: 0.75rem; }
  .cal-month-label { font-size: 0.9rem; }
  .cal-nav-btn { width: 32px; height: 32px; font-size: 1rem; }
  .cal-day-head { font-size: 0.65rem; padding: 0.3rem 0; }
  .cal-event-chip { font-size: 0.5rem; padding: 1px 2px; }
}

.cal-reserve-link {
  display: flex; justify-content: center; margin-top: 1.5rem;
}
.cal-loading {
  text-align: center; padding: 2rem; color: #718096; font-size: 0.85rem;
}
</style>

<script>
(function() {
  const SEASON_START = '2026-07-03';
  const SEASON_END   = '2026-09-06';
  const MONTHS = ['', '1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
  const DAYS   = ['日', '月', '火', '水', '木', '金', '土'];

  let calData = {};      // date → day object
  let weatherData = {}; // date → emoji string
  let currentMonth = 7; // 7=July
  const today = new Date().toISOString().slice(0, 10);

  function inSeason(d) { return d >= SEASON_START && d <= SEASON_END; }

  // テキストラベル
  const LABEL_BBQ = `<span class="cal-lbl-bbq">BBQ</span>`;
  const LABEL_SW  = `<span class="cal-lbl-sw">SW</span>`;

  // WMO コード → 天気絵文字
  const WMO_EMOJI = {
    0:'☀️',1:'🌤',2:'⛅',3:'☁️',
    45:'🌫',48:'🌫',
    51:'🌦',53:'🌦',55:'🌦',
    61:'🌧',63:'🌧',65:'🌧',
    71:'🌨',73:'🌨',75:'🌨',77:'❄️',
    80:'🌦',81:'🌦',82:'🌦',
    85:'🌨',86:'🌨',
    95:'⛈',96:'⛈',99:'⛈'
  };
  function wmoEmoji(c) { return WMO_EMOJI[c] || (c<=48?'🌫':c<=65?'🌧':c<=82?'🌦':'⛈'); }

  function statusDot(s) {
    if (s === 'open')    return '<span class="cal-s-dot cal-s-open"></span>';
    if (s === 'limited') return '<span class="cal-s-dot cal-s-limited"></span>';
    if (s === 'full')    return '<span class="cal-s-dot cal-s-full"></span>';
    return '<span class="cal-s-dot cal-s-none"></span>';
  }

  // データ取得（予約状況 + 天気予報を並列フェッチ）
  async function fetchCalendar() {
    const calFetch = fetch('/api/calendar?from=' + SEASON_START + '&to=' + SEASON_END)
      .then(r => r.json())
      .catch(() => ({ days: [] }));
    const wxFetch = fetch('https://api.open-meteo.com/v1/forecast?latitude=35.2948&longitude=139.574&daily=weathercode&timezone=Asia%2FTokyo&forecast_days=16')
      .then(r => r.json())
      .catch(() => null);

    const [calJson, wxJson] = await Promise.all([calFetch, wxFetch]);

    calData = {};
    (calJson.days || []).forEach(d => { calData[d.date] = d; });

    weatherData = {};
    if (wxJson?.daily?.time) {
      wxJson.daily.time.forEach((date, i) => {
        weatherData[date] = wmoEmoji(wxJson.daily.weathercode[i]);
      });
    }

    renderDesktop();
  }

  // ===== デスクトップ =====
  window.calPrevMonth = function() {
    if (currentMonth > 7) { currentMonth--; renderDesktop(); }
  };
  window.calNextMonth = function() {
    if (currentMonth < 9) { currentMonth++; renderDesktop(); }
  };

  function renderDesktop() {
    document.getElementById('cal-month-label').textContent = '2026年 ' + MONTHS[currentMonth];
    document.getElementById('cal-prev').disabled = currentMonth <= 7;
    document.getElementById('cal-next').disabled = currentMonth >= 9;

    const grid = document.getElementById('cal-grid');
    // ヘッダー行を残して日付セルを削除
    const heads = grid.querySelectorAll('.cal-day-head');
    grid.innerHTML = '';
    heads.forEach(h => grid.appendChild(h));

    const firstDay = new Date(2026, currentMonth - 1, 1).getDay();
    const lastDate = new Date(2026, currentMonth, 0).getDate();

    // 空セル
    for (let i = 0; i < firstDay; i++) {
      const el = document.createElement('div');
      el.className = 'cal-cell empty';
      grid.appendChild(el);
    }

    for (let d = 1; d <= lastDate; d++) {
      const dateStr = `2026-${String(currentMonth).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const dow = new Date(2026, currentMonth - 1, d).getDay();
      const dayData = calData[dateStr];
      const isToday = dateStr === today;
      const inSeas = inSeason(dateStr);

      const el = document.createElement('div');
      el.className = 'cal-cell' +
        (isToday ? ' is-today' : '') +
        (!inSeas ? ' off-season' : '') +
        (inSeas  ? ' is-link'   : '');
      if (inSeas) el.addEventListener('click', () => { location.href = 'reserve.html?date=' + dateStr; });

      const wxEmoji = weatherData[dateStr] || '';
      let inner = `<div class="cal-date-num ${dow===0?'cal-date-sun':dow===6?'cal-date-sat':''}">
        ${d}${wxEmoji ? `<span class="cal-wx">${wxEmoji}</span>` : ''}
      </div>`;

      if (inSeas) {
        inner += `<div class="cal-icons">
          <div class="cal-icon-row">${LABEL_BBQ} ${statusDot(dayData?.bbq?.status)}</div>
          <div class="cal-icon-row">${LABEL_SW} ${statusDot(dayData?.ls?.status)}</div>
        </div>`;
        if (dayData?.events?.length) {
          inner += '<div class="cal-events">' +
            dayData.events.map(e => `<span class="cal-event-chip ${e.type}" title="${e.title}">${e.title}</span>`).join('') +
            '</div>';
        }
      }

      el.innerHTML = inner;
      grid.appendChild(el);
    }
  }

  // 初期化
  if (today >= '2026-07-03') {
    currentMonth = parseInt(today.slice(5, 7));
    if (currentMonth < 7) currentMonth = 7;
    if (currentMonth > 9) currentMonth = 9;
  }
  fetchCalendar();
})();
</script>
