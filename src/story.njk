---
permalink: /story.html
---
{% set page_title = "PUENTEの想い — PUENTE seaside house" %}
{% set page_description = "なぜPUENTEをつくったのか。自然と出会い、笑顔がつながる場所。逗子海岸の海の家PUENTEが届けたい体験と想い。" %}
{% set og_title = "PUENTEの想い — PUENTE seaside house" %}
{% set og_description = "ただの海の家ではない。自然・子ども・大人・つながりという価値を届ける場所、PUENTEの想いと挑戦。" %}
{% set og_image = "images/ogp-story.jpg" %}
{% set head_extra %}
  <style>
    .story-lead {
      max-width: 720px;
      margin: 0 auto;
      font-size: 1.05rem;
      line-height: 2;
    }
    .story-quote {
      max-width: 720px;
      margin: 0 auto;
      padding: 32px;
      background: var(--white);
      border-left: 4px solid var(--teal);
      border-radius: 0 var(--radius-card) var(--radius-card) 0;
      box-shadow: var(--shadow);
      font-family: var(--font-heading-jp);
      font-size: 1.05rem;
      line-height: 2;
      color: var(--dark-text);
    }
    .story-quote .quote-author {
      margin-top: 1rem;
      font-family: var(--font-body);
      font-size: 0.85rem;
      color: var(--muted);
    }
    .value-cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: 900px;
      margin: 0 auto;
    }
    .value-card {
      text-align: center;
      padding: 32px 24px;
      background: var(--white);
      border-radius: var(--radius-card);
      box-shadow: var(--shadow);
    }
    .value-card .value-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }
    .challenge-box {
      max-width: 720px;
      margin: 0 auto;
      background: var(--white);
      border-radius: var(--radius-card);
      box-shadow: var(--shadow);
      overflow: hidden;
    }
    .challenge-box .challenge-body {
      padding: 32px;
    }
    .challenge-img {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      background: linear-gradient(135deg, var(--teal), var(--turquoise));
    }
    .scene-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
      max-width: 900px;
      margin: 0 auto;
    }
    .scene-item {
      display: flex;
      flex-direction: column;
      gap: 16px;
      background: var(--white);
      border-radius: var(--radius-card);
      overflow: hidden;
      box-shadow: var(--shadow);
    }
    .scene-item img {
      width: 100%;
      aspect-ratio: 3/2;
      object-fit: cover;
    }
    .scene-item .scene-body {
      padding: 16px 24px 24px;
    }
    .timeline {
      max-width: 720px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
    }
    .timeline-item {
      display: flex;
      gap: 20px;
      padding: 24px 0;
      border-bottom: 1px solid #E2E8F0;
    }
    .timeline-item:last-child { border-bottom: none; }
    .timeline-time {
      flex-shrink: 0;
      width: 60px;
      font-family: var(--font-accent);
      font-size: 0.9rem;
      color: var(--teal);
      font-weight: 600;
      padding-top: 2px;
    }
    .cta-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      max-width: 600px;
      margin: 0 auto;
    }
    .cta-card {
      background: var(--white);
      border-radius: var(--radius-card);
      padding: 24px;
      text-align: center;
      box-shadow: var(--shadow);
    }
    .cta-card h3 { margin-bottom: 0.5rem; }
    @media (min-width: 768px) {
      .value-cards { grid-template-columns: repeat(3, 1fr); }
      .scene-grid { grid-template-columns: repeat(2, 1fr); }
      .scene-item { flex-direction: column; }
      .cta-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
{% endset %}
{% include "header.njk" %}

  <!-- EDIT: story-hero — ファーストビュー -->
  <section class="hero" style="min-height: 500px; height: 70vh;">
    <div class="hero-bg">
      <img src="{{ story.hero_image }}" alt="{{ story.hero_alt }}" loading="eager">
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="text-accent" style="font-size: 0.9rem; color: var(--deep-ocean); text-shadow: 0 0 16px rgba(255,255,255,0.8); letter-spacing: 0.15em; margin-bottom: 0.5rem;">Our Story</p>
      <h1>{{ story.hero_h1 | safe }}</h1>
      <p class="tagline">{{ story.hero_tagline }}</p>
    </div>
  </section>

  <!-- EDIT: puente-about — PUENTEとは？ -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <span>What is PUENTE?</span>
        <h2>PUENTEとは？</h2>
      </div>
      <div class="value-cards">
        {% for card in story.about_cards %}
        <div class="value-card reveal">
          <div class="value-icon">{{ card.icon }}</div>
          <h3>{{ card.title }}</h3>
          <p>{{ card.description }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- EDIT: why-puente — なぜつくったのか -->
  <section class="section" style="background: var(--white);">
    <div class="container">
      <div class="section-title">
        <span>Why we started</span>
        <h2>なぜPUENTEをつくったのか</h2>
      </div>
      <div class="story-lead mb-4">
        {% for p in story.why_paragraphs %}
        <p>{{ p }}</p>
        {% endfor %}
      </div>
      <div class="story-quote reveal">
        <p>{{ story.quote_text }}</p>
        <p class="quote-author">{{ story.quote_author }}</p>
      </div>
    </div>
  </section>

  <!-- EDIT: challenge-2025 — 2025年の挑戦 -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <span>Challenge</span>
        <h2>2025年の挑戦</h2>
      </div>
      <div class="challenge-box reveal">
        <img src="{{ story.challenge_image }}" alt="PUENTEチーム" class="challenge-img">
        <div class="challenge-body">
          <h3>{{ story.challenge_title }}</h3>
          {% for p in story.challenge_paragraphs %}
          <p>{{ p }}</p>
          {% endfor %}
          <p class="text-muted" style="font-size: 0.85rem;">※ クラウドファンディングページへのリンクはオープン後に掲載予定</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EDIT: kids-experience — 子どもたちに届けたい体験 -->
  <section class="section" style="background: var(--white);">
    <div class="container">
      <div class="section-title">
        <span>For Kids</span>
        <h2>子どもたちに届けたい体験</h2>
      </div>
      <p class="text-center story-lead mb-4" style="max-width: 640px; margin-left: auto; margin-right: auto;">
        {{ story.kids_intro | safe }}
      </p>
      <div class="scene-grid">
        {% for scene in story.kids_scenes %}
        <div class="scene-item reveal">
          <img src="{{ scene.image }}" alt="{{ scene.alt }}" loading="lazy">
          <div class="scene-body">
            <h3>{{ scene.title }}</h3>
            <p class="text-muted">{{ scene.description }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- EDIT: for-adults — 大人にとってのPUENTE -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <span>For Adults</span>
        <h2>大人にとってのPUENTE</h2>
      </div>
      <p class="text-center story-lead mb-4" style="max-width: 640px; margin-left: auto; margin-right: auto;">
        {{ story.adults_intro | safe }}
      </p>
      <div class="scene-grid">
        {% for scene in story.adults_scenes %}
        <div class="scene-item reveal">
          <img src="{{ scene.image }}" alt="{{ scene.alt }}" loading="lazy">
          <div class="scene-body">
            <h3>{{ scene.title }}</h3>
            <p class="text-muted">{{ scene.description }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- EDIT: story-gallery — ギャラリー（1日の流れ） -->
  <section class="section" style="background: var(--white);">
    <div class="container">
      <div class="section-title">
        <span>A Day at PUENTE</span>
        <h2>PUENTEの1日</h2>
      </div>
      <div class="timeline">
        {% for item in story.timeline %}
        <div class="timeline-item">
          <div class="timeline-time">{{ item.time }}</div>
          <div>
            <h3 style="font-size: 1rem;">{{ item.title }}</h3>
            <p class="text-muted">{{ item.description }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
      <div class="gallery-grid mt-3">
        {% for img in gallery.story %}
        <div class="gallery-item"><img src="{{ img.image }}" alt="{{ img.alt }}" loading="lazy"></div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- EDIT: future — これからのPUENTE -->
  <section class="section">
    <div class="container" style="max-width: 720px;">
      <div class="section-title">
        <span>The Future</span>
        <h2>これからのPUENTE</h2>
      </div>
      <div class="story-lead">
        {% for p in story.future_paragraphs %}
        <p>{{ p }}</p>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- EDIT: story-cta — CTA・問い合わせ -->
  <section class="cta-section">
    <div class="container">
      <h2>PUENTEとつながる</h2>
      <p style="color: rgba(255,255,255,0.8); margin-bottom: 2rem;">応援・協賛・イベント貸切のご相談もお気軽にどうぞ。</p>
      <div class="cta-grid">
        {% for card in story.cta_cards %}
        <div class="cta-card">
          <h3>{{ card.icon }} {{ card.title }}</h3>
          <p class="text-muted" style="font-size: 0.85rem;">{{ card.description }}</p>
          <a href="{{ card.url }}"{% if card.external %} target="_blank" rel="noopener"{% endif %} class="btn btn-outline" style="margin-top: 0.5rem; padding: 8px 20px; font-size: 0.85rem;">{{ card.label }}</a>
        </div>
        {% endfor %}
      </div>
      <div class="mt-3">
        <a href="reserve.html" class="btn btn-primary">予約する</a>
      </div>
    </div>
  </section>

{% include "footer.njk" %}
