<style>
  /* ===== 森沢かな1日店長 イベントページ専用スタイル ===== */

  /* --- ヒーロー：空→海のグラデーション --- */
  .ev-hero {
    position: relative;
    overflow: hidden;
    padding: 110px 20px 0;
    text-align: center;
    color: var(--white);
    background: linear-gradient(180deg,
      #9FE0F0 0%,
      #6EC9E8 30%,
      var(--deep-ocean) 78%,
      #23759C 100%);
  }
  .ev-hero-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .ev-eyebrow {
    font-family: var(--font-accent);
    font-size: 0.8rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #FFF6D6;
    margin-bottom: 0.8rem;
  }
  .ev-eyebrow span { white-space: nowrap; } /* 語句の途中で折り返さない */

  /* 折り返し制御ユーティリティ */
  .nw { white-space: nowrap; }
  .br-sp { display: none; } /* スマホ専用改行 */
  @media (max-width: 767px) {
    .br-sp { display: inline; }
    .ev-eyebrow { font-size: 0.68rem; letter-spacing: 3px; }
    .ev-eyebrow .ev-eyebrow-loc { display: none; } /* スマホでは所在地を省略して2行に収める */
    .ev-title-en span { display: block; } /* 英字サブタイトルは2行に分けて中央揃え */
  }
  .ev-handwrite {
    font-family: var(--font-handwrite);
    font-size: clamp(1.6rem, 6vw, 2.4rem);
    color: var(--warm-gold);
    display: inline-block;
    transform: rotate(-2deg);
    margin-bottom: 0.4rem;
    text-shadow: 0 2px 10px rgba(0,60,90,0.25);
  }
  .ev-title {
    font-family: var(--font-heading-jp);
    font-size: clamp(2.6rem, 11vw, 4.4rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 0.3rem;
    color: var(--white);
    text-shadow: 0 3px 16px rgba(0,60,90,0.35);
  }
  .ev-title-en {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 3vw, 1.15rem);
    letter-spacing: 6px;
    color: rgba(255,255,255,0.85);
    margin-bottom: 1.4rem;
  }
  .ev-date-badge {
    display: inline-block;
    background: var(--warm-gold);
    color: #7A5A00;
    font-weight: 700;
    font-family: var(--font-body);
    font-size: clamp(1rem, 3.6vw, 1.25rem);
    padding: 10px 26px;
    border-radius: 999px;
    transform: rotate(1.5deg);
    box-shadow: 0 4px 14px rgba(0,50,80,0.25);
    margin-bottom: 2.2rem;
  }
  .ev-date-badge small { font-weight: 600; font-size: 0.8em; }

  /* ポラロイド風写真 */
  .ev-polaroid {
    display: inline-block;
    background: var(--white);
    padding: 12px 12px 44px;
    border-radius: 6px;
    box-shadow: 0 14px 34px rgba(0,40,70,0.35);
    transform: rotate(-2.5deg);
    max-width: min(78vw, 400px);
    position: relative;
    margin-bottom: -60px; /* 波と重ねる */
    transition: transform 0.35s ease;
  }
  .ev-polaroid:hover { transform: rotate(-1deg) scale(1.02); }
  .ev-polaroid::before { /* マスキングテープ */
    content: '';
    position: absolute;
    top: -14px; left: 50%;
    width: 110px; height: 28px;
    transform: translateX(-50%) rotate(-3deg);
    background: rgba(126,232,208,0.75);
    border-radius: 2px;
  }
  .ev-polaroid img {
    width: 100%;
    display: block;
    border-radius: 3px;
  }
  .ev-polaroid figcaption {
    font-family: var(--font-handwrite);
    font-size: 1.35rem;
    color: #5A6B7A;
    position: absolute;
    bottom: 8px; left: 0; right: 0;
    text-align: center;
  }

  /* 浮遊する夏モチーフ */
  .ev-float {
    position: absolute;
    font-size: clamp(1.6rem, 5vw, 2.6rem);
    opacity: 0.85;
    animation: ev-bob 5s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }
  .ev-float.f1 { top: 16%; left: 6%; animation-delay: 0s; }
  .ev-float.f2 { top: 112px; right: 4%; animation-delay: 1.2s; } /* 固定ヘッダー／ハンバーガーの下に確実に逃がす */
  .ev-float.f3 { top: 46%; left: 2%; animation-delay: 2.1s; } /* ポラロイド写真の左外側に逃がす */
  .ev-float.f4 { top: 40%; right: 6%; animation-delay: 0.7s; }
  @keyframes ev-bob {
    0%, 100% { transform: translateY(0) rotate(-4deg); }
    50%      { transform: translateY(-14px) rotate(5deg); }
  }

  /* 波の区切り */
  .ev-wave { display: block; width: 100%; height: 90px; margin-top: 0; }
  .ev-wave path { fill: var(--sand); }

  /* --- ヒーロー直下の予約CTA --- */
  .ev-hero-cta-wrap {
    text-align: center;
    background: var(--sand);
    padding: 20px 20px 16px;
  }
  .ev-hero-cta-wrap .btn-primary {
    font-size: 1.05rem;
    padding: 14px 42px;
    box-shadow: 0 8px 22px rgba(240,136,112,0.35);
  }
  .ev-hero-cta-note {
    margin: 10px 0 0;
    font-size: 0.82rem;
    color: var(--muted);
  }

  /* --- ティッカー（マーキー） --- */
  .ev-ticker {
    background: var(--teal);
    color: var(--white);
    overflow: hidden;
    white-space: nowrap;
    padding: 10px 0;
    font-family: var(--font-display);
    letter-spacing: 3px;
    font-size: 0.95rem;
  }
  .ev-ticker-track {
    display: inline-block;
    animation: ev-marquee 22s linear infinite;
  }
  .ev-ticker-track span { margin: 0 1.6em; }
  @keyframes ev-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* --- タイムテーブル --- */
  .ev-parts { display: grid; gap: 18px; margin-top: 30px; }
  @media (min-width: 768px) { .ev-parts { grid-template-columns: repeat(3, 1fr); } }
  .ev-part-card {
    background: var(--white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow);
    padding: 26px 20px;
    text-align: center;
    border-top: 6px solid var(--part-color, var(--teal));
    transition: transform 0.25s ease;
  }
  .ev-part-card:hover { transform: translateY(-6px); }
  .ev-part-card.p1 { --part-color: var(--coral); }
  .ev-part-card.p2 { --part-color: var(--teal); }
  .ev-part-card.p3 { --part-color: var(--deep-ocean); }
  .ev-part-label {
    font-family: var(--font-heading-jp);
    font-weight: 700;
    font-size: clamp(1.5rem, 6vw, 1.9rem);
    color: var(--dark-text);
    margin-bottom: 4px;
  }
  .ev-part-time {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 5vw, 1.7rem);
    color: var(--deep-ocean);
    margin-bottom: 10px;
  }
  .ev-part-price { color: var(--dark-text); font-weight: 600; }
  .ev-part-price small { display: block; color: var(--muted); font-weight: 400; margin-top: 2px; }
  .ev-perk-pill {
    display: inline-block;
    background: #FFF3C4;
    color: #7A5A00;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 2px 12px;
    border-radius: 999px;
    margin-top: 6px;
    white-space: nowrap;
  }

  /* 通し券ハイライト */
  .ev-pass {
    margin-top: 22px;
    background: linear-gradient(120deg, #FFF3C4, #FFE08A);
    border: 2px solid #E0A800;
    border-radius: var(--radius-card);
    padding: 24px 20px;
    text-align: center;
  }
  .ev-pass strong { font-size: clamp(1.2rem, 4.5vw, 1.5rem); color: #7A5A00; }
  .ev-pass .ev-pass-bonus {
    display: inline-block;
    margin-top: 8px;
    background: var(--white);
    border-radius: 999px;
    padding: 6px 18px;
    font-size: 0.9rem;
    color: var(--dark-text);
    box-shadow: var(--shadow);
  }

  /* --- 物販 --- */
  .ev-goods { display: grid; gap: 16px; margin-top: 30px; }
  @media (min-width: 768px) { .ev-goods { grid-template-columns: repeat(3, 1fr); } }
  .ev-goods-card {
    background: var(--white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow);
    padding: 24px 18px;
    text-align: center;
  }
  .ev-goods-emoji { font-size: 2.2rem; display: block; margin-bottom: 8px; }
  .ev-goods-name { font-weight: 700; color: var(--dark-text); margin-bottom: 4px; }
  .ev-goods-price {
    font-family: var(--font-display);
    font-size: 1.4rem;
    color: var(--coral);
  }
  .ev-goods-note { font-size: 0.82rem; color: var(--muted); margin-top: 6px; }

  /* --- BBQバナー --- */
  .ev-bbq {
    background: linear-gradient(120deg, var(--coral), var(--sunset-orange));
    border-radius: var(--radius-card);
    color: var(--white);
    padding: 34px 24px;
    text-align: center;
    box-shadow: var(--shadow);
    position: relative;
    overflow: hidden;
  }
  .ev-bbq::after {
    content: '🍖';
    position: absolute;
    font-size: 7rem;
    right: -18px; bottom: -26px;
    opacity: 0.18;
    transform: rotate(-15deg);
  }
  .ev-bbq h3 {
    font-family: var(--font-heading-jp);
    font-size: clamp(1.3rem, 5vw, 1.7rem);
    margin-bottom: 6px;
    color: var(--white);
  }
  .ev-bbq-price {
    font-family: var(--font-display);
    font-size: clamp(2rem, 8vw, 2.8rem);
    margin: 6px 0 10px;
  }
  .ev-bbq-tags { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .ev-bbq-tags span {
    background: rgba(255,255,255,0.22);
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 999px;
    padding: 6px 16px;
    font-size: 0.88rem;
  }

  /* --- 注意事項・CTA --- */
  .ev-notes { max-width: 640px; margin: 30px auto 0; }
  .ev-notes li { margin-bottom: 8px; color: var(--dark-text); font-size: 0.95rem; }
  .ev-cta {
    text-align: center;
    padding: 60px 20px 70px;
    background: linear-gradient(180deg, var(--sand), #EAF7F4);
    overflow: hidden; /* フルブリード画像のはみ出しで横スクロールを出さない */
  }
  .ev-cta .btn-primary {
    font-size: 1.15rem;
    padding: 18px 56px;
    box-shadow: 0 8px 22px rgba(240,136,112,0.45);
  }
  .ev-cta-note { color: var(--muted); font-size: 0.88rem; margin-top: 14px; }

  .ev-cta-catch {
    width: 50%;
    margin: 0 auto;
    font-family: var(--font-handwrite);
    font-size: clamp(2.3rem, 6vw, 3.6rem); /* セクション内で最大の文字 */
    line-height: 1.4;
    color: var(--teal);
    text-align: center;
  }
  @media (max-width: 767px) {
    .ev-cta-catch {
      width: 90%;
      font-size: clamp(2.1rem, 9vw, 2.8rem);
    }
  }
  .ev-cta-heading {
    font-family: var(--font-heading-jp);
    color: var(--deep-ocean);
    margin: 28px 0 22px;
  }

  .ev-section-lead {
    text-align: center;
    color: var(--dark-text);
    max-width: 640px;
    margin: 0 auto;
    line-height: 2;
  }
</style>
{% endset %}
