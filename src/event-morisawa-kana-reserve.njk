{% set og_title = "ご予約 — 森沢かな 1日店長 @ PUENTE seaside house" %}
{% set og_description = "7/30(木)開催。各部¥3,000（ブロマイド付き）／1日通し¥7,500。先着順・満席になり次第終了。" %}
{% set og_image = "images/event-morisawa-kana.jpg" %}
{% set head_extra %}
<style>
  /* ===== イベント予約ページ専用スタイル ===== */
  .evr-hero {
    background: linear-gradient(180deg, #9FE0F0 0%, #6EC9E8 45%, var(--deep-ocean) 100%);
    color: var(--white);
    text-align: center;
    padding: 110px 20px 26px;
    position: relative;
    overflow: hidden;
  }
  .evr-hero .ev-handwrite {
    font-family: var(--font-handwrite);
    font-size: clamp(1.3rem, 5vw, 1.8rem);
    color: var(--warm-gold);
    display: inline-block;
    transform: rotate(-2deg);
  }
  .evr-hero h1 {
    font-family: var(--font-heading-jp);
    font-size: clamp(1.7rem, 6.5vw, 2.6rem);
    color: var(--white);
    margin: 0.2rem 0 0.6rem;
    text-shadow: 0 3px 14px rgba(0,60,90,0.35);
  }
  .evr-hero .evr-date {
    display: inline-block;
    background: var(--warm-gold);
    color: #7A5A00;
    font-weight: 700;
    padding: 6px 20px;
    border-radius: 999px;
    font-size: 0.95rem;
    transform: rotate(1deg);
    margin-bottom: 0.6rem;
  }
  .evr-hero .evr-back {
    display: block;
    margin-top: 10px;
    color: rgba(255,255,255,0.85);
    font-size: 0.85rem;
    text-decoration: underline;
  }
  .evr-wave { display: block; width: 100%; height: 60px; }
  .evr-wave path { fill: var(--sand); }

  /* 部選択カード（複数選択可） */
  .evr-parts { display: grid; gap: 12px; }
  .evr-part {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: var(--white);
    border: 2px solid #E2E8F0;
    border-radius: var(--radius-card);
    padding: 14px 16px;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .evr-part.selected { border-color: var(--coral); background: #FFF9F6; box-shadow: 0 4px 14px rgba(240,136,112,0.22); }
  .evr-part.soldout { opacity: 0.55; cursor: not-allowed; }
  .evr-part-head {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .evr-part-head input { accent-color: var(--coral); width: 20px; height: 20px; flex-shrink: 0; }
  .evr-part-badge {
    display: inline-flex;
    align-items: center; justify-content: center;
    width: 30px; height: 30px;
    border-radius: 50%;
    color: var(--white);
    font-family: var(--font-display);
    font-size: 0.95rem;
    flex-shrink: 0;
  }
  .evr-part.p1 .evr-part-badge { background: var(--coral); }
  .evr-part.p2 .evr-part-badge { background: var(--teal); }
  .evr-part.p3 .evr-part-badge { background: var(--deep-ocean); }
  .evr-part-title {
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--dark-text);
    flex: 1;
    min-width: 0;
  }
  .evr-part-time {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--deep-ocean);
    white-space: nowrap;
    padding-left: 60px; /* head の badge 位置に揃える */
    font-size: 1rem;
  }
  .evr-part-perk {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding-left: 60px;
  }
  .evr-part-price { color: var(--coral); font-weight: 700; white-space: nowrap; }
  .evr-remaining {
    font-size: 0.78rem;
    font-weight: 700;
    border-radius: 999px;
    padding: 4px 10px;
    flex-shrink: 0;
    margin-left: auto;
    white-space: nowrap;
  }
  .evr-remaining.ok { background: #E3F7F2; color: #1E8A76; }
  .evr-remaining.few { background: #FFF2E3; color: #C46A1F; }
  .evr-remaining.full { background: #FBE4E0; color: #C0392B; }

  /* 特典ピル（1特典=1行で収まる） */
  .evr-perk-tag {
    display: inline-block;
    background: #FFF3C4;
    color: #7A5A00;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }

  /* 通し券アップセル */
  .evr-pass-upsell {
    margin-top: 12px;
    border: 1.5px dashed #E0C860;
    background: #FFFBEC;
    border-radius: var(--radius-card);
    padding: 12px 14px;
    font-size: 0.88rem;
    color: var(--dark-text);
    line-height: 1.8;
    transition: background 0.25s ease;
  }
  .evr-pass-upsell.active {
    background: linear-gradient(120deg, #FFF3C4, #FFE08A);
    border-style: solid;
    border-color: #E0A800;
    font-weight: 700;
  }

  @media (max-width: 600px) {
    .evr-part { padding: 12px; }
    .evr-part-time, .evr-part-perk { padding-left: 60px; }
    .evr-part-title { font-size: 1.1rem; }
  }

  /* BBQオプション（イチオシ推し） */
  .evr-bbq-card {
    position: relative;
    border: 2px solid #F5C4B4;
    background: linear-gradient(150deg, #FFFDFB, #FFF4EF);
  }
  .evr-reco-ribbon {
    position: absolute;
    top: -12px;
    right: 14px;
    background: linear-gradient(120deg, var(--coral), var(--sunset-orange));
    color: var(--white);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 999px;
    box-shadow: 0 3px 8px rgba(240,136,112,0.4);
  }
  .evr-bbq-copy { color: var(--dark-text); font-size: 0.92rem; margin-bottom: 0.9rem; line-height: 1.8; }
  .evr-bbq-label {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: linear-gradient(120deg, #FFF4EF, #FFEDE3);
    border: 2px solid #F5C4B4;
    border-radius: var(--radius-card);
    padding: 16px;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .evr-bbq-label.selected { border-color: var(--coral); box-shadow: 0 4px 14px rgba(240,136,112,0.3); }
  .evr-bbq-label input { accent-color: var(--coral); width: 20px; height: 20px; margin-top: 2px; }
  .evr-bbq-label strong { color: var(--dark-text); font-size: 1.05rem; }
  .evr-bbq-label .rsv-note { display: block; margin-top: 4px; }
  .evr-bbq-label .evr-perk-tag { margin-top: 6px; margin-right: 6px; }

  /* 物販の希望 */
  .evr-goods-opts { display: grid; gap: 10px; }
  .evr-goods-opt {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: var(--white);
    border: 2px solid #E2E8F0;
    border-radius: var(--radius-card);
    padding: 12px 14px;
    cursor: pointer;
    transition: border-color 0.2s ease;
  }
  .evr-goods-opt.selected { border-color: var(--teal); background: #F4FBF9; }
  .evr-goods-opt input { accent-color: var(--teal); width: 18px; height: 18px; margin-top: 2px; flex-shrink: 0; }
  .evr-goods-opt strong { color: var(--dark-text); display: block; }
  .evr-goods-opt .evr-perk-tag { margin-top: 4px; }

  /* 完了画面: チケットとオペレーション案内 */
  .evr-op-note {
    background: #FFF3C4;
    border: 1.5px solid #E0A800;
    border-radius: var(--radius-card);
    padding: 12px 16px;
    font-size: 0.92rem;
    color: #5C4400;
    margin: 1rem 0;
    line-height: 1.8;
  }
  .evr-ticket { margin-top: 1.2rem; padding-top: 1.2rem; border-top: 1px dashed #D8E0E8; }
  .evr-ticket-part {
    display: inline-block;
    background: var(--deep-ocean);
    color: var(--white);
    font-weight: 700;
    font-size: 0.88rem;
    padding: 4px 16px;
    border-radius: 999px;
    margin-bottom: 0.6rem;
  }

  /* 確認テーブル */
  .evr-confirm-table { width: 100%; border-collapse: collapse; font-size: 0.95rem; }
  .evr-confirm-table td { padding: 10px 0; border-bottom: 1px solid #EEF2F6; }
  .evr-confirm-table td:first-child { color: var(--muted); width: 110px; vertical-align: top; }

  #ev-loading { text-align: center; color: var(--muted); padding: 40px 0; }
</style>
{% endset %}
{% include "header.njk" %}

<!-- EDIT: イベント予約ヒーロー -->
<section class="evr-hero">
  <p class="ev-handwrite">ご予約はこちら！</p>
  <h1>森沢かな 1日店長</h1>
  <p class="evr-date"><span style="white-space:nowrap">2026.7.30 THU</span> <span style="white-space:nowrap">@ PUENTE seaside house</span></p>
  <a class="evr-back" href="event-morisawa-kana.html">← イベント詳細にもどる</a>
</section>
<svg class="evr-wave" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true" style="background: var(--deep-ocean);">
  <path d="M0,30 C240,60 480,5 720,26 C960,48 1200,10 1440,34 L1440,60 L0,60 Z"></path>
</svg>

<section class="section" style="padding-top: 30px;">
  <div class="container" style="max-width: 680px;">

    <div id="reservation-app">

      <div id="ev-loading">予約メニューを読み込み中…</div>

      <!-- フォーム本体 -->
      <div id="form-body" class="hidden">

        <div class="rsv-card">
          <h3 class="rsv-step-title">① ご希望の部を選ぶ <span class="rsv-note" style="font-weight:400;font-size:0.85rem;">（複数選択OK）</span></h3>
          <div id="part-options" class="evr-parts"></div>
          <div id="pass-upsell" class="evr-pass-upsell">
            💡 <strong>3部すべて選ぶと「1日通し券 ¥7,500」に自動でおトク切替！</strong><br>
            <span class="evr-perk-tag">🎬 通し特典：10秒動画つき</span> <span class="evr-perk-tag">💰 ¥1,500おトク</span>
          </div>
        </div>

        <div class="rsv-card">
          <h3 class="rsv-step-title">② 人数</h3>
          <div class="number-stepper">
            <button type="button" class="num-btn" data-target="num-people" data-action="minus">−</button>
            <input type="number" id="num-people-display" class="num-value" value="1" min="1" max="10">
            <button type="button" class="num-btn" data-target="num-people" data-action="plus">+</button>
          </div>
          <p class="rsv-note mt-1">※ 1組10名まで</p>
        </div>

        <div class="rsv-card evr-bbq-card">
          <span class="evr-reco-ribbon">🔥 イチオシ</span>
          <h3 class="rsv-step-title">③ BBQプラン <span class="rsv-note" style="font-weight:400;font-size:0.85rem;">（任意）</span></h3>
          <p class="evr-bbq-copy">店長のお手伝い付きで楽しめるのは<strong>BBQプランだけ</strong>！<br class="br-sp">海を見ながらみんなで乾杯しよう 🍻</p>
          <label class="evr-bbq-label" id="bbq-label">
            <input type="checkbox" id="bbq-check">
            <span>
              <strong>🍖 BBQプランを申し込む ¥8,500</strong>
              <span class="rsv-note">お支払いは当日現地にて。</span>
              <span class="evr-perk-tag">🍻 飲み放題付き</span><span class="evr-perk-tag">💁‍♀️ 店長のお手伝い付き</span>
            </span>
          </label>
        </div>

        <div class="rsv-card">
          <h3 class="rsv-step-title">④ 物販の希望 <span class="rsv-note" style="font-weight:400;font-size:0.85rem;">（任意・複数OK）</span></h3>
          <p class="rsv-note" style="margin-bottom:0.75rem;">お支払いは当日会場にて。事前に希望を教えてもらえると、当日のご案内がスムーズです！</p>
          <div class="evr-goods-opts">
            <label class="evr-goods-opt">
              <input type="checkbox" class="goods-check" value="ツーショット">
              <span>
                <strong>📸 ツーショット ¥2,000</strong>
                <span class="evr-perk-tag">🎁 5枚おまとめで特典あり ※当日のおたのしみ</span>
              </span>
            </label>
            <label class="evr-goods-opt">
              <input type="checkbox" class="goods-check" value="ランダムチェキ">
              <span><strong>🎞️ ランダムチェキ ¥1,500</strong></span>
            </label>
            <label class="evr-goods-opt">
              <input type="checkbox" class="goods-check" value="個撮20秒">
              <span><strong>🎬 個撮20秒 ¥2,500</strong></span>
            </label>
          </div>
        </div>

        <div class="rsv-card">
          <h3 class="rsv-step-title">⑤ お客様情報</h3>
          <div class="rsv-fields">
            <div class="rsv-field">
              <label class="rsv-label">お名前 <span class="required">必須</span></label>
              <input type="text" id="customer-name" class="rsv-input" placeholder="山田 花子">
            </div>
            <div class="rsv-field">
              <label class="rsv-label">メールアドレス <span class="required">必須</span></label>
              <input type="email" id="customer-email" class="rsv-input" placeholder="example@email.com">
            </div>
          </div>
        </div>

        <div class="rsv-card">
          <h3 class="rsv-step-title">⑥ 通知方法</h3>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="notif-channel" value="line" checked>
              <span>LINE <small>（推奨）</small></span>
            </label>
            <label class="radio-label">
              <input type="radio" name="notif-channel" value="email">
              <span>メールのみ</span>
            </label>
          </div>
          <div id="line-cta" class="line-cta-box">
            <p class="rsv-note">予約確定後、LINE公式アカウントに予約番号を送ると確認・リマインド通知が届きます。</p>
            <a href="{{ site.line_url }}" target="_blank" rel="noopener" class="btn btn-line btn-sm">LINE 友だち追加 →</a>
          </div>
        </div>

        <div class="rsv-card">
          <h3 class="rsv-step-title">備考 <span class="rsv-note" style="font-weight:400;font-size:0.85rem;">（任意）</span></h3>
          <p class="rsv-note" style="margin-bottom:0.75rem;">BBQをお申し込みの方でアレルギー・苦手な食材がある場合は必ずご記入ください。</p>
          <textarea id="customer-notes" class="rsv-input rsv-textarea" placeholder="例：エビアレルギーあり など" rows="3"></textarea>
        </div>

        <div id="form-errors" class="rsv-errors hidden"></div>

        <div class="text-center mt-3">
          <button id="confirm-btn" class="btn btn-primary" style="width: 100%; max-width: 360px;">内容を確認する →</button>
        </div>
      </div>

      <!-- 確認画面 -->
      <div id="confirm-screen" class="hidden">
        <div class="rsv-card">
          <h3 class="rsv-step-title">予約内容の確認</h3>
          <div id="confirm-details" class="confirm-details"></div>
          <p id="submit-error" class="rsv-submit-error hidden"></p>
          <div class="rsv-confirm-btns">
            <button id="back-btn" class="btn btn-outline">← 修正する</button>
            <button id="submit-btn" class="btn btn-primary">予約を確定する</button>
          </div>
        </div>
      </div>

      <!-- 完了画面 -->
      <div id="success-screen" class="hidden">
        <div class="rsv-card rsv-success">
          <div class="success-icon">✓</div>
          <h2 style="color: var(--teal);">予約が完了しました</h2>
          <p>ご予約ありがとうございます、<strong id="success-name"></strong> 様。<br>7月30日、PUENTEでお会いしましょう 🌊</p>
          <div class="evr-op-note">🎫 当日は受付で<strong>「森沢かなイベントの予約」</strong>とお伝えのうえ、下のQRコード（予約番号）をご提示ください</div>
          <div id="success-tickets"></div>
          <div id="success-line-prompt" class="line-cta-box mt-2">
            <p class="rsv-note"><strong>LINE通知を受け取るには</strong><br>下記から友だち追加後、この予約番号をLINEで送ってください。</p>
            <a href="{{ site.line_url }}" target="_blank" rel="noopener" class="btn btn-line btn-sm">LINE 友だち追加 →</a>
          </div>
          <p class="rsv-note mt-2">確認メールをお送りしました（複数の部をご予約の場合は部ごとに届きます）。届かない場合はLINEよりお問い合わせください。</p>
        </div>
      </div>

    </div>

    <!-- 注意書き -->
    <div class="info-box" style="margin-top: 2rem;">
      <ul style="font-size: 0.9rem; line-height: 1.9; padding-left: 1.2em;">
        <li>お支払いはすべて<strong>当日・現地にて</strong>お願いします（事前決済はありません）</li>
        <li>先着順・満席になり次第受付終了です</li>
        <li>物販（ツーショット・チェキ等）は当日会場でお求めいただけます</li>
        <li>キャンセル・変更は<a href="https://lin.ee/7boYnzG" target="_blank" rel="noopener">LINE公式アカウント</a>までご連絡ください</li>
      </ul>
    </div>
  </div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="/js/event-reserve.js"></script>
