---
permalink: /index.html
---
{% set page_title = "PUENTE seaside house — 逗子海岸の美容特化海の家" %}
{% set page_description = "逗子海岸で唯一の美容特化海の家『PUENTE seaside house』。芸能界で活躍するヘアメイクアーティストがオーナーを務め、ReFaのシャワーヘッドやライスフォース等の高級アメニティが無料で使い放題。SNS映えする空間で、海を満喫したあとも美しい仕上がりをお約束します。ご予約受付中。" %}
{% set og_title = "PUENTE seaside house — 逗子海岸の美容特化海の家" %}
{% set og_description = "海水浴後も美しく。ReFaシャワーヘッド・ドライヤー、ライスフォースなどスキンケアが無料で使える逗子海岸唯一の美容特化海の家。" %}
{% set og_image = "images/ogp-top.jpg" %}
{% set og_type = "website" %}
{% set twitter_card = "summary_large_image" %}
{% set showCountdown = true %}
{% include "header.njk" %}

  <!-- EDIT: hero-image / hero-copy — FV写真・キャッチコピー -->
  <section class="hero">
    <div class="hero-bg">
      <img src="{{ hero.image }}" alt="{{ hero.alt }}" loading="eager">
    </div>
    <div class="hero-overlay"></div>
    <!-- 天気ウィジェット -->
    <div class="hero-weather" id="hero-weather" style="display:none;" aria-live="polite">
      <div class="hw-header">今日の天気</div>
      <div class="hw-row">
        <div class="hw-icon" id="hw-icon">—</div>
        <div class="hw-body">
          <div class="hw-main-row">
            <span class="hw-desc" id="hw-desc">—</span>
            <span class="hw-temp" id="hw-temp">—</span>
          </div>
          <div class="hw-label">逗子海岸 現在の天気</div>
        </div>
      </div>
    </div>
    <p class="hero-catch">海辺の美容サロンー逗子海岸唯一の美容に特化した海の家</p>
    <div class="hero-content">
      <p class="text-accent" style="font-family: var(--font-handwrite); font-size: 1.6rem; margin-bottom: 0.5rem; color: var(--deep-ocean); text-shadow: 0 0 16px rgba(255,255,255,0.8); letter-spacing: 0.05em;">Zushi Beach</p>
      <h1><span class="hero-h1-visual">PUENTE</span><span class="sr-only">逗子海岸唯一の美容特化海の家「PUENTE seaside house」</span></h1>
      <a href="reserve.html" class="btn btn-primary btn-hero">{{ hero.cta_text }}</a>
    </div>
  </section>

  <style>
    .ev-banner-wrap {
      padding: 20px;
      background: var(--sand);
    }
    .ev-banner {
      max-width: 860px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 20px;
      background: linear-gradient(120deg,#FFF3C4,#FFE08A);
      border: 2px solid #E0A800;
      border-radius: var(--radius-card);
      box-shadow: var(--shadow);
      text-decoration: none;
      transition: transform .25s ease;
    }
    .ev-banner:hover {
      transform: translateY(-3px);
    }
    .ev-banner-photo {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      object-fit: cover;
      object-position: 50% 32%; /* 顔の位置に合わせて切り抜き */
      border: 3px solid var(--white);
      flex-shrink: 0;
    }
    .ev-banner-date {
      display: inline-block;
      background: var(--coral);
      color: var(--white);
      font-weight: 700;
      font-size: .78rem;
      padding: 3px 10px;
      border-radius: 999px;
      letter-spacing: 1px;
    }
    .ev-banner-hand {
      display: block;
      font-family: var(--font-handwrite);
      color: #9A7100;
      font-size: 1.05rem;
      margin: 4px 0 2px;
      transform: rotate(-1.5deg);
    }
    .ev-banner-title {
      display: block;
      font-family: var(--font-heading-jp);
      font-weight: 700;
      font-size: 1.25rem;
      color: var(--dark-text);
    }
    .ev-banner-title small {
      font-family: var(--font-display);
      font-size: .7rem;
      letter-spacing: 2px;
      color: #9A7100;
      margin-left: 8px;
    }
    .ev-banner-cta {
      margin-left: auto;
      flex-shrink: 0;
      background: var(--white);
      color: var(--coral);
      font-weight: 700;
      font-size: .85rem;
      padding: 8px 16px;
      border-radius: 999px;
      box-shadow: var(--shadow);
      white-space: nowrap;
    }
    @media (max-width: 600px) {
      .ev-banner-cta { display: none; }
      .ev-banner { padding: 12px 14px; }
    }
  </style>
  <!-- EDIT: 森沢かな1日店長イベント 告知バナー（イベント終了後はこのセクションごと削除） -->
  <section class="ev-banner-wrap">
    <a href="event-morisawa-kana.html" class="ev-banner">
      <img src="images/event-morisawa-kana.jpg" alt="森沢かな" class="ev-banner-photo">
      <span class="ev-banner-body">
        <span class="ev-banner-date">7.30 THU</span>
        <span class="ev-banner-hand">1日店長イベント開催！</span>
        <span class="ev-banner-title"><span style="white-space:nowrap">森沢かな</span> <small style="white-space:nowrap">MORISAWA KANA</small></span>
      </span>
      <span class="ev-banner-cta">詳しくみる →</span>
    </a>
  </section>

  <script>
    (function () {
      var target = new Date('2026-07-03T09:00:00+09:00').getTime();
      function pad(n) { return String(n).padStart(2, '0'); }
      function tick() {
        var diff = target - Date.now();
        if (diff <= 0) {
          var bar = document.getElementById('header-countdown');
          if (bar) bar.style.display = 'none';
          return;
        }
        document.getElementById('cd-days').textContent    = pad(Math.floor(diff / 86400000));
        document.getElementById('cd-hours').textContent   = pad(Math.floor(diff % 86400000 / 3600000));
        document.getElementById('cd-minutes').textContent = pad(Math.floor(diff % 3600000  / 60000));
        document.getElementById('cd-seconds').textContent = pad(Math.floor(diff % 60000    / 1000));
        setTimeout(tick, 1000);
      }
      tick();
    })();
  </script>

  <!-- 営業カレンダー・予約状況 -->
  {% include "calendar-widget.njk" %}

  <!-- EDIT: feature-1 / feature-2 / feature-3 — 3つの特徴カード -->
  <section class="section">
    <div class="container">
      <div class="section-title">
        <span>Features</span>
        <h2>PUENTEの3つの特徴</h2>
      </div>
      <div class="cards-grid">
        {% for f in features %}
        <div class="card reveal">
          <div class="card-icon"><i data-lucide="{{ f.icon }}"></i></div>
          <h3>{{ f.title }}</h3>
          <p>{{ f.description }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- EDIT: amenity-preview — アメニティ写真4枚 -->
  <section class="section" style="background: var(--white);">
    <div class="container">
      <div class="section-title">
        <span>Amenity</span>
        <h2>充実のビューティーアメニティ</h2>
      </div>
      <p class="text-muted" style="max-width: 700px; margin: 0 auto 2rem; font-size: 0.95rem; line-height: 1.8;">海から上がった後も美しく。PUENTEでは、ReFaのシャワーヘッドや高性能ドライヤーを完備した清潔なパウダールームをご用意しています。逗子海岸で唯一、ライスフォース等の高級スキンケアも無料で使い放題。海水浴後もしっかりと髪と肌のケアが可能です。</p>
      <div class="gallery-grid">
        {% for img in gallery.amenity_preview %}
        <div class="gallery-item">
          <img src="{{ img.image }}" alt="{{ img.alt }}" loading="lazy">
        </div>
        {% endfor %}
      </div>
      <div class="text-center mt-3">
        <a href="amenity.html" class="btn btn-outline">アメニティを詳しく見る →</a>
      </div>
    </div>
  </section>

  <!-- EDIT: owner-preview — オーナー写真・肩書き・コメント -->
  <section class="section">
    <div class="container">
      <div class="profile reveal">
        <img src="{{ owner.image }}" alt="オーナー" class="profile-img">
        <div>
          <span class="badge">{{ owner.index_preview.badge }}</span>
          <h2 class="mt-2">{{ owner.index_preview.title }}</h2>
          <p>{{ owner.index_preview.description }}</p>
          <a href="owner.html" class="btn btn-outline">もっと見る →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- EDIT: media — メディア掲載動画 -->
  <section class="section" style="background: var(--white);">
    <div class="container" style="max-width: 760px;">
      <div class="section-title">
        <span>Media</span>
        <h2>メディア掲載</h2>
      </div>
      <div class="media-badge reveal">
        <span class="media-badge-label">📺 フジテレビ「めざましテレビ」で紹介されました</span>
      </div>
      <div class="yt-facade reveal" data-vid="4nGg9eulWPI" role="button" tabindex="0" aria-label="動画を再生">
        <img
          src="https://i.ytimg.com/vi/4nGg9eulWPI/hqdefault.jpg"
          alt="めざましテレビ PUENTE seaside house 紹介映像"
          class="yt-thumb"
          loading="lazy"
          width="480" height="360"
        >
        <div class="yt-play-btn" aria-hidden="true">
          <svg viewBox="0 0 68 48" width="68" height="48"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55c-2.93.78-4.63 3.26-5.42 6.19C.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="#f00"/><path d="M45 24 27 14v20" fill="#fff"/></svg>
        </div>
      </div>
    </div>
  </section>
  <style>
    .media-badge { text-align: center; margin-bottom: 1.25rem; }
    .media-badge-label {
      display: inline-block;
      background: #FFF8E1;
      border: 1.5px solid #FFD96A;
      border-radius: 99px;
      padding: 0.4rem 1.2rem;
      font-size: 0.85rem;
      font-weight: 700;
      color: #7B5800;
    }
    .yt-facade {
      position: relative;
      width: 100%;
      aspect-ratio: 16/9;
      background: #000;
      border-radius: var(--radius-card);
      overflow: hidden;
      cursor: pointer;
    }
    .yt-thumb {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: opacity 0.2s;
    }
    .yt-facade:hover .yt-thumb { opacity: 0.85; }
    .yt-play-btn {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
    }
    .yt-play-btn svg {
      filter: drop-shadow(0 2px 8px rgba(0,0,0,0.4));
      transition: transform 0.15s;
    }
    .yt-facade:hover .yt-play-btn svg { transform: scale(1.1); }
  </style>
  <script>
  (function(){
    document.querySelectorAll('.yt-facade').forEach(function(el){
      function activate() {
        var vid = el.dataset.vid;
        var iframe = document.createElement('iframe');
        iframe.src = 'https://www.youtube.com/embed/' + vid + '?autoplay=1&rel=0';
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
        iframe.allowFullscreen = true;
        iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:none;';
        el.innerHTML = '';
        el.appendChild(iframe);
      }
      el.addEventListener('click', activate);
      el.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' ') activate(); });
    });
  })();
  </script>

  <!-- EDIT: gallery — 雰囲気ギャラリー写真8枚 -->
  <section class="section" style="background: var(--white);">
    <div class="container">
      <div class="section-title">
        <span>Gallery</span>
        <h2>PUENTEの雰囲気</h2>
      </div>
      <div class="gallery-grid">
        {% for img in gallery.index %}
        <div class="gallery-item"><img src="{{ img.image }}" alt="{{ img.alt }}" loading="lazy"></div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- 1-Day Journey -->
  <section class="journey-section">
    <div class="container" style="max-width: 900px;">
      <div class="section-title">
        <span>{{ journey.title }}</span>
        <h2>{{ journey.subtitle }}</h2>
      </div>
      {% for step in journey.steps %}
      <div class="journey-step reveal">
        <div class="journey-img">
          <img src="{{ step.image }}" alt="{{ step.alt }}" loading="lazy">
        </div>
        <div class="journey-body">
          <div class="journey-number">{{ step.number }}</div>
          <div class="journey-time">{{ step.time }}</div>
          <h3>{{ step.title }}</h3>
          <p class="journey-problem">{{ step.problem }}</p>
          <p class="journey-solution">{{ step.solution }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- EDIT: cta-bottom — CTAコピー・MAP -->
  <section class="cta-section">
    <div class="container">
      <h2>海に来たのに、来る前より綺麗になれる夏。</h2>
      <p>逗子海岸まで新宿から約60分。湘南新宿ラインで日帰り圏内。</p>
      <div class="map-container" style="margin-bottom: 2rem;">
        <iframe src="{{ site.maps_embed_url }}" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
      <a href="reserve.html" class="btn btn-primary">予約する</a>
    </div>
  </section>

  <!-- EDIT: shop-info — 店舗情報（ローカルSEO） -->
  <section class="section" style="background: var(--white);">
    <div class="container" style="max-width: 800px;">
      <div class="section-title">
        <span>Information</span>
        <h2>店舗情報</h2>
      </div>
      <dl class="shop-info-list">
        <div class="shop-info-item">
          <dt>店舗名</dt>
          <dd>{{ business.store_name }}</dd>
        </div>
        <div class="shop-info-item">
          <dt>所在地</dt>
          <dd>{{ business.address }}</dd>
        </div>
        <div class="shop-info-item">
          <dt>営業期間</dt>
          <dd>{{ business.period }}</dd>
        </div>
        <div class="shop-info-item">
          <dt>営業時間</dt>
          <dd>{{ business.hours }}（ラストオーダー {{ business.last_order }}）</dd>
        </div>
        <div class="shop-info-item">
          <dt>アクセス</dt>
          <dd>{% for t in business.access.train %}{{ t.line }}より{{ t.time }}{% if not loop.last %} / {% endif %}{% endfor %}</dd>
        </div>
        <div class="shop-info-item">
          <dt>設備</dt>
          <dd>{{ business.facilities }}</dd>
        </div>
        <div class="shop-info-item">
          <dt>定休日</dt>
          <dd>{{ business.holidays }}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- EDIT: faq — よくある質問（ロングテールSEO） -->
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <div class="section-title">
        <span>FAQ</span>
        <h2>よくある質問</h2>
      </div>
      <div class="faq-list">
        {% for item in faq %}
        <details class="faq-item">
          <summary>{{ item.question }}</summary>
          <p>{{ item.answer }}</p>
        </details>
        {% endfor %}
      </div>
    </div>
  </section>

<script>
(function() {
  const WMO_EMOJI = {
    0:'☀️',1:'🌤',2:'⛅',3:'☁️',
    45:'🌫',48:'🌫',
    51:'🌦',53:'🌦',55:'🌦',
    61:'🌧',63:'🌧',65:'🌧',
    71:'🌨',73:'🌨',75:'🌨',77:'❄️',
    80:'🌦',81:'🌦',82:'🌦',
    85:'🌨',86:'🌨',
    95:'⛈',96:'⛈',99:'⛈'
  };
  const WMO_TEXT = {
    0:'快晴',1:'晴れ',2:'晴れ時々曇り',3:'曇り',
    45:'霧',48:'霧',
    51:'霧雨',53:'霧雨',55:'霧雨',
    61:'雨',63:'雨',65:'大雨',
    71:'雪',73:'雪',75:'大雪',77:'霧雪',
    80:'にわか雨',81:'にわか雨',82:'にわか雨',
    85:'にわか雪',86:'にわか雪',
    95:'雷雨',96:'雷雨',99:'雷雨'
  };
  function emoji(c) { return WMO_EMOJI[c] || (c<=48?'🌫':c<=65?'🌧':c<=82?'🌦':'⛈'); }
  function text(c)  { return WMO_TEXT[c]  || '—'; }

  const CACHE_KEY = 'puente_wx_v1';
  const CACHE_TTL = 15 * 60 * 1000; // 15分

  function applyWeather(cw) {
    document.getElementById('hw-icon').textContent = emoji(cw.weathercode);
    document.getElementById('hw-desc').textContent = text(cw.weathercode);
    document.getElementById('hw-temp').textContent = Math.round(cw.temperature) + '°C';
    document.getElementById('hero-weather').style.display = 'flex';
  }

  function fetchFresh() {
    fetch('https://api.open-meteo.com/v1/forecast?latitude=35.2948&longitude=139.574&current_weather=true&timezone=Asia%2FTokyo')
      .then(r => r.json())
      .then(data => {
        const cw = data.current_weather;
        if (!cw) return;
        try { localStorage.setItem(CACHE_KEY, JSON.stringify({ cw, ts: Date.now() })); } catch (_) {}
        applyWeather(cw);
      })
      .catch(function(){});
  }

  // キャッシュがあれば即表示（stale-while-revalidate）
  try {
    const cached = JSON.parse(localStorage.getItem(CACHE_KEY) || 'null');
    if (cached?.cw) {
      applyWeather(cached.cw);
      // 15分以上古い場合はバックグラウンドで更新
      if (Date.now() - cached.ts > CACHE_TTL) fetchFresh();
      return; // 新鮮なキャッシュならfetchしない
    }
  } catch (_) {}

  // キャッシュなし → 通常フェッチ
  fetchFresh();
})();
</script>
{% include "footer.njk" %}
