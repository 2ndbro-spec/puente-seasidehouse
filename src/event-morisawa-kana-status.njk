  <p class="ev-handwrite">予約状況</p>
  <h1>森沢かな 1日店長</h1>
  <p class="evs-date">2026.7.30 THU</p>
</section>

<section class="section" style="padding-top: 0;">
  <div class="evs-wrap">

    <div id="evs-loading">予約状況を読み込み中…</div>
    <div id="evs-error" class="hidden"></div>

    <div id="evs-content" class="hidden">

      <div class="evs-total-card">
        <p class="evs-total-label">現在の予約合計</p>
        <p class="evs-total-num"><span id="evs-total-value">0</span><small>名</small></p>
      </div>

      <p class="evs-section-label">部別 内訳</p>
      <div id="evs-parts" class="evs-parts"></div>

      <div id="evs-bbq" class="evs-bbq-card">
        <span class="evs-bbq-icon">🍖</span>
        <div>
          <p class="evs-bbq-title">BBQプラン申込</p>
          <p class="evs-bbq-count" id="evs-bbq-count">0名・0組</p>
        </div>
      </div>

      <div class="evs-footer-bar">
        <p class="evs-updated-at">最終更新 <span id="evs-updated-time">--:--:--</span></p>
        <button id="evs-refresh-btn" class="btn btn-outline">いま更新</button>
        <p class="evs-auto-note">60秒ごとに自動更新されます</p>
      </div>

    </div>

  </div>
</section>

{% include "footer.njk" %}

<script>
(function () {
  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function formatPartName(name) {
    // 例: "【1部】森沢かな1日店長 11:00-13:00" → "1部 11:00-13:00"
    var partMatch = String(name).match(/【(.+?)】/);
    var timeMatch = String(name).match(/(\d{1,2}:\d{2}\s*-\s*\d{1,2}:\d{2})/);
    if (partMatch) {
      return timeMatch ? (partMatch[1] + ' ' + timeMatch[1]) : partMatch[1];
    }
    return String(name);
  }

  function progressColor(pct) {
    if (pct >= 80) return 'var(--coral)';
    if (pct >= 50) return 'var(--warm-gold)';
    return 'var(--teal)';
  }

  function pad2(n) { return String(n).padStart(2, '0'); }

  function formatTime(date) {
    return pad2(date.getHours()) + ':' + pad2(date.getMinutes()) + ':' + pad2(date.getSeconds());
  }

  var loadingEl = document.getElementById('evs-loading');
  var errorEl = document.getElementById('evs-error');
  var contentEl = document.getElementById('evs-content');
  var totalValueEl = document.getElementById('evs-total-value');
  var partsEl = document.getElementById('evs-parts');
  var bbqCountEl = document.getElementById('evs-bbq-count');
  var updatedTimeEl = document.getElementById('evs-updated-time');
  var refreshBtn = document.getElementById('evs-refresh-btn');

  var params = new URLSearchParams(window.location.search);
  var token = params.get('token');

  function showError(message) {
    loadingEl.classList.add('hidden');
    contentEl.classList.add('hidden');
    errorEl.classList.remove('hidden');
    errorEl.textContent = message;
  }

  function render(data) {
    totalValueEl.textContent = data.total_reserved;

    var partsHtml = (data.parts || []).map(function (part) {
      var capacity = part.capacity || 0;
      var reserved = part.reserved || 0;
      var pct = capacity > 0 ? Math.round((reserved / capacity) * 100) : 0;
      var isFull = part.remaining <= 0;
      var color = progressColor(pct);
      var widthPct = Math.min(pct, 100);
      var name = escapeHtml(formatPartName(part.name));

      return '' +
        '<div class="evs-part-card">' +
          '<div class="evs-part-head">' +
            '<span class="evs-part-name">' + name + '</span>' +
            '<span class="evs-part-count">' + reserved + ' / ' + capacity + ' 名</span>' +
          '</div>' +
          '<div class="evs-progress-track">' +
            '<div class="evs-progress-fill" style="width:' + widthPct + '%;background:' + color + ';"></div>' +
          '</div>' +
          '<div class="evs-part-foot">' +
            '<span>' + part.groups + '組・残り' + Math.max(part.remaining, 0) + '席</span>' +
            (isFull ? '<span class="evs-badge-full">満席</span>' : '') +
          '</div>' +
        '</div>';
    }).join('');

    partsEl.innerHTML = partsHtml;

    var bbq = data.bbq || { people: 0, groups: 0 };
    bbqCountEl.textContent = bbq.people + '名・' + bbq.groups + '組';

    updatedTimeEl.textContent = formatTime(new Date());

    loadingEl.classList.add('hidden');
    errorEl.classList.add('hidden');
    contentEl.classList.remove('hidden');
  }

  function fetchStatus() {
    return fetch('/api/event-status?token=' + encodeURIComponent(token))
      .then(function (res) {
        if (res.status === 401) {
          showError('URLが正しくありません。主催者にお問い合わせください');
          return null;
        }
        if (!res.ok) {
          throw new Error('status ' + res.status);
        }
        return res.json();
      })
      .then(function (data) {
        if (data) render(data);
      })
      .catch(function () {
        showError('通信エラーが発生しました。時間をおいて再度お試しください。');
      });
  }

  if (!token) {
    showError('アクセスにはトークン付きURLが必要です');
    return;
  }

  fetchStatus();
  setInterval(fetchStatus, 60000);

  if (refreshBtn) {
    refreshBtn.addEventListener('click', function () {
      fetchStatus();
    });
  }
})();
</script>
