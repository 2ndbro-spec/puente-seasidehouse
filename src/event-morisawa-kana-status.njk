<style>
  /* ===== イベント予約状況ページ専用スタイル ===== */
  .evs-hero {
    background: linear-gradient(180deg, #9FE0F0 0%, #2E8CB8 100%);
    color: var(--white);
    text-align: center;
    padding: 90px 20px 26px;
  }
  .evs-hero .ev-handwrite {
    font-family: var(--font-handwrite);
    font-size: clamp(1.2rem, 5vw, 1.6rem);
    color: var(--warm-gold);
    display: inline-block;
    transform: rotate(-2deg);
  }
  .evs-hero h1 {
    font-family: var(--font-heading-jp);
    font-size: clamp(1.5rem, 6vw, 2.2rem);
    color: var(--white);
    margin: 0.2rem 0 0.7rem;
    text-shadow: 0 3px 14px rgba(0,60,90,0.35);
  }
  .evs-hero .evs-date {
    display: inline-block;
    background: var(--warm-gold);
    color: #7A5A00;
    font-weight: 700;
    padding: 6px 20px;
    border-radius: 999px;
    font-size: 0.9rem;
  }

  .evs-wrap { max-width: 640px; margin: 0 auto; padding: 28px 20px 60px; }

  #evs-loading, #evs-error {
    text-align: center;
    color: var(--muted);
    padding: 60px 20px;
    font-size: 0.95rem;
  }
  #evs-error { color: var(--coral); font-weight: 600; }

  .evs-total-card {
    background: var(--white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow);
    text-align: center;
    padding: 24px 20px;
    margin-bottom: 20px;
  }
  .evs-total-label {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0 0 6px;
  }
  .evs-total-num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 10vw, 3rem);
    color: var(--deep-ocean);
    font-weight: 700;
    line-height: 1;
    margin: 0;
  }
  .evs-total-num small {
    font-family: var(--font-body);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--dark-text);
    margin-left: 4px;
  }

  .evs-section-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--muted);
    letter-spacing: 0.05em;
    margin: 24px 0 10px;
  }

  .evs-parts { display: grid; gap: 12px; }
  .evs-part-card {
    background: var(--white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow);
    padding: 16px;
  }
  .evs-part-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 10px;
  }
  .evs-part-name {
    font-weight: 700;
    color: var(--dark-text);
    font-size: 0.98rem;
  }
  .evs-part-count {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--deep-ocean);
    font-size: 1rem;
    white-space: nowrap;
  }
  .evs-progress-track {
    width: 100%;
    height: 8px;
    border-radius: 999px;
    background: #E8EEF3;
    overflow: hidden;
  }
  .evs-progress-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.4s ease;
  }
  .evs-part-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 8px;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .evs-badge-full {
    display: inline-block;
    background: #FBE4E0;
    color: #C0392B;
    font-weight: 700;
    font-size: 0.72rem;
    padding: 2px 10px;
    border-radius: 999px;
  }

  .evs-bbq-card {
    display: flex;
    align-items: center;
    gap: 14px;
    background: linear-gradient(120deg, #FFF4EF, #FFEDE3);
    border: 2px solid #F5C4B4;
    border-radius: var(--radius-card);
    padding: 16px;
    margin-top: 20px;
  }
  .evs-bbq-icon { font-size: 1.8rem; flex-shrink: 0; }
  .evs-bbq-title { font-weight: 700; color: var(--dark-text); margin: 0 0 2px; }
  .evs-bbq-count { color: var(--muted); font-size: 0.9rem; margin: 0; }

  .evs-footer-bar {
    text-align: center;
    margin-top: 32px;
    padding-top: 20px;
    border-top: 1px solid #EEF2F6;
  }
  .evs-updated-at {
    color: var(--muted);
    font-size: 0.85rem;
    margin: 0 0 10px;
  }
  .evs-auto-note {
    color: var(--muted);
    font-size: 0.78rem;
    margin: 10px 0 0;
  }
</style>
