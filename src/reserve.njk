---
permalink: /reserve.html
---
{% set page_title = "予約・アクセス — PUENTE seaside house" %}
{% set page_description = "PUENTE seaside houseの予約・料金・アクセス情報。逗子海岸の美容特化海の家。" %}
{% set og_title = "予約・アクセス — PUENTE seaside house" %}
{% set og_description = "予約・料金・アクセス情報。逗子海岸駅から徒歩10分。" %}
{% set og_image = "images/ogp-reserve.jpg" %}
{% include "header.njk" %}

  <!-- EDIT: reserve-header -->
  <section class="page-header">
    <p class="text-accent" style="opacity: 0.8; margin-bottom: 0.5rem;">Reservation</p>
    <h1>予約・アクセス</h1>
    <p>お気軽にご予約ください。当日のご来店も歓迎です。</p>
  </section>

  <!-- 予約フォーム -->
  <section class="section">
    <div class="container" style="max-width: 740px;">
      <div class="section-title">
        <span>Reserve</span>
        <h2>ご予約</h2>
      </div>

      <div id="reservation-app">

        <!-- メニュータブ -->
        <div id="menu-tabs" class="menu-tabs"></div>

        <!-- フォーム本体 -->
        <div id="form-body">

          <!-- 日付 -->
          <div id="step-date" class="rsv-card hidden">
            <h3 class="rsv-step-title">日付を選んでください</h3>
            <input type="date" id="reservation-date" class="rsv-date-input">
            <div id="availability-loading" class="rsv-loading hidden">空き状況を確認中…</div>
          </div>

          <!-- BBQ用フィールド -->
          <div id="bbq-fields" class="hidden">
            <div class="rsv-card">
              <h3 class="rsv-step-title">時間帯を選んでください <span class="rsv-note">（2時間制）</span></h3>
              <div id="time-slots-grid" class="time-slots-grid"></div>
            </div>

            <div class="rsv-card">
              <h3 class="rsv-step-title">人数</h3>
              <div class="number-stepper">
                <button type="button" class="num-btn" data-target="num-people" data-action="minus">−</button>
                <span id="num-people-display" class="num-value">2</span>
                <button type="button" class="num-btn" data-target="num-people" data-action="plus">+</button>
              </div>
              <p class="rsv-note mt-1">※ 2名〜100名</p>
            </div>

            <div id="addon-options" class="rsv-card hidden"></div>
          </div>

          <!-- ロッカーシャワー用フィールド -->
          <div id="ls-fields" class="hidden">
            <div class="rsv-card">
              <p id="ls-remaining" class="ls-remaining"></p>
              <div class="ls-gender-row">
                <div>
                  <h3 class="rsv-step-title">男性</h3>
                  <div class="number-stepper">
                    <button type="button" class="num-btn" data-target="num-male" data-action="minus">−</button>
                    <span id="num-male-display" class="num-value">0</span>
                    <input type="hidden" id="num-male" value="0">
                    <button type="button" class="num-btn" data-target="num-male" data-action="plus">+</button>
                  </div>
                </div>
                <div>
                  <h3 class="rsv-step-title">女性</h3>
                  <div class="number-stepper">
                    <button type="button" class="num-btn" data-target="num-female" data-action="minus">−</button>
                    <span id="num-female-display" class="num-value">0</span>
                    <input type="hidden" id="num-female" value="0">
                    <button type="button" class="num-btn" data-target="num-female" data-action="plus">+</button>
                  </div>
                </div>
              </div>
            </div>
            <div class="rsv-card">
              <h3 class="rsv-step-title">チェックイン予定時間</h3>
              <select id="checkin-time" class="rsv-select"></select>
            </div>
          </div>

          <!-- 予約種別 -->
          <div class="rsv-card">
            <h3 class="rsv-step-title">予約の種類</h3>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="booking-type" value="confirmed" checked>
                <span>本予約</span>
              </label>
              <label class="radio-label">
                <input type="radio" name="booking-type" value="pending">
                <span>仮予約 <small>（3日以内に確定してください）</small></span>
              </label>
            </div>
          </div>

          <!-- 通知方法 -->
          <div class="rsv-card">
            <h3 class="rsv-step-title">通知方法</h3>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="notif-channel" value="line" checked>
                <span>LINE <small>（推奨）</small></span>
              </label>
              <label class="radio-label">
                <input type="radio" name="notif-channel" value="email">
                <span>メールのみ</span>
              </label>
            </div>
            <div id="line-cta" class="line-cta-box">
              <p class="rsv-note">予約確定後、LINE公式アカウントに予約番号を送ると確認・リマインド通知が届きます。</p>
              <a href="{{ site.line_url }}" target="_blank" rel="noopener" class="btn btn-line btn-sm">LINE 友だち追加 →</a>
            </div>
          </div>

          <!-- お客様情報 -->
          <div class="rsv-card">
            <h3 class="rsv-step-title">お客様情報</h3>
            <div class="rsv-fields">
              <div class="rsv-field">
                <label class="rsv-label">お名前 <span class="required">必須</span></label>
                <input type="text" id="customer-name" class="rsv-input" placeholder="山田 花子">
              </div>
              <div class="rsv-field">
                <label class="rsv-label">メールアドレス <span class="required">必須</span></label>
                <input type="email" id="customer-email" class="rsv-input" placeholder="example@email.com">
              </div>
            </div>
          </div>

          <!-- エラー表示 -->
          <div id="form-errors" class="rsv-errors hidden"></div>

          <div class="text-center mt-3">
            <button id="confirm-btn" class="btn btn-primary" style="width: 100%; max-width: 360px;">内容を確認する →</button>
          </div>
        </div>

        <!-- 確認画面 -->
        <div id="confirm-screen" class="hidden">
          <div class="rsv-card">
            <h3 class="rsv-step-title">予約内容の確認</h3>
            <div class="confirm-details"></div>
            <p id="submit-error" class="rsv-submit-error hidden"></p>
            <div class="rsv-confirm-btns">
              <button id="back-btn" class="btn btn-outline">← 修正する</button>
              <button id="submit-btn" class="btn btn-primary">予約を確定する</button>
            </div>
          </div>
        </div>

        <!-- 完了画面 -->
        <div id="success-screen" class="hidden">
          <div class="rsv-card rsv-success">
            <div class="success-icon">✓</div>
            <h2 style="color: var(--teal);">予約が完了しました</h2>
            <p>ご予約ありがとうございます、<strong id="success-name"></strong> 様。</p>
            <p class="rsv-note">予約種別: <strong id="success-status"></strong></p>
            <div class="rsv-code-box">
              <p class="rsv-note">予約番号</p>
              <p class="rsv-code" id="success-code"></p>
            </div>
            <div id="qr-code" class="qr-wrapper"></div>
            <p class="rsv-note mt-2">このQRコードを当日スタッフにご提示ください</p>
            <div id="success-line-prompt" class="line-cta-box mt-2">
              <p class="rsv-note"><strong>LINE通知を受け取るには</strong><br>下記から友だち追加後、この予約番号をLINEで送ってください。</p>
              <a href="{{ site.line_url }}" target="_blank" rel="noopener" class="btn btn-line btn-sm">LINE 友だち追加 →</a>
            </div>
            <p class="rsv-note mt-2">確認メールをお送りしました。届かない場合はLINEよりお問い合わせください。</p>
          </div>
        </div>

      </div>

      <!-- LINE -->
      <div class="info-box text-center" style="margin-top: 2rem;">
        <h3>💬 LINEでもお問い合わせOK</h3>
        <p>空き状況の確認・ご質問はLINE公式アカウントへ。</p>
        <a href="{{ site.line_url }}" target="_blank" rel="noopener" class="btn btn-line" style="margin-top: 1rem;">LINE公式アカウントを追加 →</a>
      </div>
    </div>
  </section>

  <!-- EDIT: price-table — 料金プラン・金額 -->
  <section class="section" style="background: var(--white);">
    <div class="container" style="max-width: 800px;">
      <div class="section-title">
        <span>Price</span>
        <h2>料金</h2>
      </div>
      <table class="price-table">
        <thead>
          <tr>
            <th>プラン</th>
            <th>料金（税込）</th>
          </tr>
        </thead>
        <tbody>
          {% for p in pricing.plans %}
          <tr>
            <td>{{ p.name }}</td>
            <td>{{ p.price }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      <p class="text-muted mt-2" style="font-size: 0.9rem;">※ 料金は変更になる場合があります。最新情報はLINEでお問い合わせください。</p>
    </div>
  </section>

  <!-- EDIT: access-info — MAP・駅からの所要時間・駐車場 -->
  <section class="section">
    <div class="container" style="max-width: 800px;">
      <div class="section-title">
        <span>Access</span>
        <h2>アクセス</h2>
      </div>

      <div class="map-container mb-4">
        <iframe src="{{ site.maps_embed_url }}" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>

      <div class="cards-grid" style="grid-template-columns: 1fr 1fr;">
        <div class="info-box">
          <h3>🚃 電車でお越しの方</h3>
          <p style="font-size: 0.9rem;">{% for t in business.access.train %}{{ t.line }} {{ t.time }}{% if not loop.last %}<br>{% endif %}{% endfor %}</p>
          <p class="text-muted" style="font-size: 0.9rem;">{% for f in business.access.from_major_stations %}{{ f.station }}から{{ f.time }}（{{ f.route }}）{% if not loop.last %}<br>{% endif %}{% endfor %}</p>
        </div>
        <div class="info-box">
          <h3>🚗 お車でお越しの方</h3>
          <p style="font-size: 0.9rem;">{{ business.access.car }}</p>
          <p class="text-muted" style="font-size: 0.9rem;">{{ business.access.parking_note | safe }}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EDIT: business-hours — 営業期間・時間・定休日 -->
  <section class="section" style="background: var(--white);">
    <div class="container" style="max-width: 800px;">
      <div class="section-title">
        <span>Info</span>
        <h2>営業情報</h2>
      </div>
      <div class="info-box">
        <table style="width: 100%; font-size: 0.9rem;">
          <tr>
            <td style="padding: 8px 0; font-weight: 600; width: 120px; vertical-align: top;">営業期間</td>
            <td style="padding: 8px 0;">{{ business.period }}</td>
          </tr>
          <tr>
            <td style="padding: 8px 0; font-weight: 600; vertical-align: top;">営業時間</td>
            <td style="padding: 8px 0;">{{ business.hours }}（ラストオーダー {{ business.last_order }}）</td>
          </tr>
          <tr>
            <td style="padding: 8px 0; font-weight: 600; vertical-align: top;">定休日</td>
            <td style="padding: 8px 0;">{{ business.holidays }}</td>
          </tr>
          <tr>
            <td style="padding: 8px 0; font-weight: 600; vertical-align: top;">悪天候時</td>
            <td style="padding: 8px 0;">{{ business.weather_notice }}</td>
          </tr>
        </table>
      </div>
    </div>
  </section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="/js/reservation.js"></script>
{% include "footer.njk" %}
